.lesson-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e0d8c8;
}
.body-text {
  font-size: 28rpx;
  color: #4a4a5a;
  margin-bottom: 16rpx;
}
.example {
  background: #faf6f0;
  border: 1rpx solid #ece6da;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin: 16rpx 0;
  font-size: 26rpx;
  line-height: 1.9;
}
.quiz-card {
  margin-bottom: 20rpx;
}
.quiz-label {
  display: block;
  font-size: 22rpx;
  color: #c87832;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.quiz-question {
  display: block;
  font-size: 30rpx;
  margin-bottom: 16rpx;
}
.options { display: flex; flex-direction: column; gap: 12rpx; }
.option {
  background: #faf6f0;
  border: 2rpx solid #e0d8c8;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
}
.option.correct { border-color: #2a7a4a; background: #e8f5ec; }
.option.wrong { border-color: #b84040; background: #fce8e8; }
.option.disabled { opacity: 0.5; }
.opt-letter {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #ece6da;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 24rpx;
  flex-shrink: 0;
}
.option.correct .opt-letter { background: #2a7a4a; color: #fff; }
.option.wrong .opt-letter { background: #b84040; color: #fff; }
.explanation {
  background: #f0ebe3;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4a4a5a;
}
