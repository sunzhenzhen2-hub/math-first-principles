.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border: 1rpx solid #ece6da;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #c87832;
}
.stat-label {
  display: block;
  font-size: 22rpx;
  color: #8a8a96;
  margin-top: 4rpx;
}

.progress-section {
  background: #fff;
  border: 1rpx solid #ece6da;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8a8a96;
  margin-bottom: 8rpx;
}

.stage-title {
  font-size: 30rpx;
  font-weight: 700;
  margin: 28rpx 0 12rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #c87832;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.topic-card {
  background: #fff;
  border: 1rpx solid #ece6da;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.topic-card.locked { opacity: 0.35; }
.topic-card.done { border-left: 6rpx solid #2a7a4a; }
.topic-icon { font-size: 48rpx; }
.topic-info { flex: 1; }
.topic-title { display: block; font-size: 28rpx; font-weight: 700; }
.topic-desc { display: block; font-size: 22rpx; color: #8a8a96; }
.topic-stars { display: block; font-size: 24rpx; margin-top: 4rpx; }
.topic-pct { font-size: 26rpx; color: #c87832; font-weight: 700; }

.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 80%;
  max-width: 600rpx;
}
.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-card input {
  border: 2rpx solid #e0d8c8;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}
.auth-switch {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8a8a96;
}
.link { color: #c87832; margin-left: 8rpx; }
.auth-error { display: block; color: #b84040; font-size: 24rpx; text-align: center; margin-top: 12rpx; }
