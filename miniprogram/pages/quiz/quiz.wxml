<!-- 测验页面 -->
<view class="container" wx:if="{{!showResult}}">
  <view class="card">
    <text class="quiz-header">{{title}} · 第 {{current + 1}}/{{total}} 题</text>
    <text class="quiz-question">{{question.question}}</text>
    <view class="options">
      <view
        wx:for="{{question.options}}"
        wx:for-item="opt"
        wx:for-index="oi"
        wx:key="oi"
        class="option {{answered ? (oi === question.answer ? 'correct' : (oi === selected && oi !== question.answer ? 'wrong' : 'disabled')) : ''}}"
        bindtap="answer"
        data-oi="{{oi}}"
      >
        <text class="opt-letter">{{letters[oi]}}</text>
        <text>{{opt}}</text>
      </view>
    </view>
    <view class="explanation" wx:if="{{showExplanation}}">
      <text>💡 解析：{{question.explanation}}</text>
    </view>
  </view>
  <button class="btn-primary" wx:if="{{showExplanation}}" bindtap="next" style="width:100%">
    {{current < total - 1 ? '下一题 →' : '查看结果 🏆'}}
  </button>
</view>

<!-- 结果页面 -->
<view class="container" wx:if="{{showResult}}">
  <view class="card" style="text-align:center">
    <text class="result-icon">{{resultIcon}}</text>
    <text class="result-title">{{resultTitle}}</text>
    <text class="result-sub">{{title}}</text>
    <text class="result-stars">{{starsStr}}</text>
    <text class="result-score">{{correct}} / {{total}}</text>
    <view class="result-info">
      <text>正确率 {{pct}}%</text>
    </view>
  </view>
  <view class="btn-row">
    <button class="btn-outline" bindtap="retry">🔄 重做</button>
    <button class="btn-primary" bindtap="goBack">📊 返回</button>
  </view>
</view>
