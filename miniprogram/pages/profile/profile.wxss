.profile-icon { display: block; font-size: 80rpx; margin-bottom: 16rpx; }
.profile-title { display: block; font-size: 30rpx; font-weight: 700; margin-bottom: 24rpx; }
.profile-header { display: flex; align-items: center; gap: 24rpx; }
.profile-avatar { font-size: 64rpx; }
.profile-name { display: block; font-size: 32rpx; font-weight: 700; }
.profile-email { display: block; font-size: 24rpx; color: #8a8a96; }

.auth-form { text-align: left; }
.auth-form input {
  border: 2rpx solid #e0d8c8;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}
.auth-switch {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8a8a96;
}
.link { color: #c87832; margin-left: 8rpx; }
.auth-error { display: block; color: #b84040; font-size: 24rpx; text-align: center; margin-top: 12rpx; }

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}
.stat-item {
  background: #faf6f0;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}
.stat-num { display: block; font-size: 40rpx; font-weight: 900; color: #c87832; }
.stat-label { display: block; font-size: 22rpx; color: #8a8a96; }

.empty-state { color: #8a8a96; font-size: 28rpx; }
.wrong-item {
  background: #faf6f0;
  border: 1rpx solid #ece6da;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}
.wrong-q { display: block; font-size: 28rpx; font-weight: 500; margin-bottom: 8rpx; }
.wrong-a { display: block; font-size: 24rpx; color: #2a7a4a; }
.wrong-u { display: block; font-size: 24rpx; color: #b84040; }
