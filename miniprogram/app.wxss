/* 全局样式 */
page {
  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;
  background: #faf6f0;
  color: #1a1a2e;
  line-height: 1.8;
}

.container {
  padding: 24rpx 32rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border: 1rpx solid #ece6da;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(26,26,46,0.06);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #c87832, #e8a85c);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-outline {
  background: #fff;
  color: #4a4a5a;
  border: 2rpx solid #e0d8c8;
  border-radius: 48rpx;
  padding: 18rpx 40rpx;
  font-size: 28rpx;
}

/* 标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 32rpx 0 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #c87832;
}

/* 高亮 */
.highlight {
  background: linear-gradient(135deg, rgba(200,120,50,0.12), rgba(26,106,106,0.06));
  border-left: 6rpx solid #c87832;
  padding: 20rpx 24rpx;
  border-radius: 0 16rpx 16rpx 0;
  margin: 20rpx 0;
  font-weight: 600;
  font-size: 28rpx;
}

/* 公式 */
.formula {
  background: #f0ebe3;
  text-align: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #c87832;
  margin: 20rpx 0;
}

/* 进度条 */
.progress-bar {
  height: 10rpx;
  background: #f0ebe3;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #c87832, #e8a85c);
}

/* 标签 */
.tag-success {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: #e8f5ec;
  color: #2a7a4a;
}

.tag-danger {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: #fce8e8;
  color: #b84040;
}
