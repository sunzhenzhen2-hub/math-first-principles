# 数学第一性原理学习系统 - 环境变量配置

# 小米 MiMo API 配置
# 从 https://mimo.mi.com 获取 API Key
AI_API_KEY=your-mimo-api-key-here
AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
AI_MODEL=mimo-v2.5

# JWT 密钥 (生产环境请修改)
MATH_SECRET_KEY=your-secret-key-here

# OpenAI 兼容配置 (可选，用于其他 AI 服务)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
